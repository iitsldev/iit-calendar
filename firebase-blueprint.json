{
  "entities": {
    "Config": {
      "title": "App Configuration",
      "description": "General application configuration and metadata",
      "type": "object",
      "properties": {
        "calendar_name": { "type": "string" },
        "version": { "type": "string" },
        "supported_calendar_types": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Event": {
      "title": "Event",
      "description": "A Buddhist event or schedule item",
      "type": "object",
      "properties": {
        "category": { "type": "string", "description": "e.g., srilanka, myanmar, thai, vietnam, IIT_2027_schedule" },
        "calendar_type": { "type": "string" },
        "event_name": { "type": "string" },
        "month": { "type": "number" },
        "day": { "type": "number" },
        "year": { "type": "number" },
        "day_of_week": { "type": "string" },
        "time": { "type": "string" },
        "subject": { "type": "string" }
      },
      "required": ["category", "calendar_type"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "A daily reflection or quote",
      "type": "object",
      "properties": {
        "quote": { "type": "string" },
        "author": { "type": "string" },
        "source": { "type": "string" }
      },
      "required": ["quote", "author"]
    },
    "GlobalChant": {
      "title": "Global Chant",
      "description": "A standard chant available to all users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title"]
    },
    "UserChant": {
      "title": "User Chant",
      "description": "A user's personal or modified chant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "totalCount": { "type": "number" },
        "lastUsed": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" },
        "milestone": { "type": "number" }
      },
      "required": ["title", "totalCount"]
    },
    "ChantSession": {
      "title": "Chant Session",
      "description": "A log of a chanting session",
      "type": "object",
      "properties": {
        "chantId": { "type": "string" },
        "count": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["chantId", "count", "timestamp"]
    }
  },
  "firestore": {
    "configs/calendar": {
      "schema": "Config",
      "description": "Calendar metadata and versioning"
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "Collection of all events across categories"
    },
    "reflections/{reflectionId}": {
      "schema": "Reflection",
      "description": "Collection of daily reflections"
    },
    "chants/{chantId}": {
      "schema": "GlobalChant",
      "description": "Master list of Buddhist chants"
    },
    "users/{userId}/chants/{userChantId}": {
      "schema": "UserChant",
      "description": "User's collection of chants and progress"
    },
    "users/{userId}/chant_sessions/{sessionId}": {
      "schema": "ChantSession",
      "description": "Chronological log of chanting activity"
    }
  }
}
