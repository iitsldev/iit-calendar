rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'vendhammanana@gmail.com' && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---

    function isValidGlobalChant(data) {
      return data.keys().hasAll(['title']) &&
             data.title is string && data.title.size() <= 200 &&
             (!('content' in data) || (data.content is string && data.content.size() <= 10000)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 50));
    }

    function isValidUserChant(data, userId) {
      return data.keys().hasAll(['title', 'totalCount']) &&
             data.title is string && data.title.size() <= 200 &&
             data.totalCount is number && data.totalCount >= 0 &&
             (!('milestone' in data) || (data.milestone is number && data.milestone >= 0));
    }

    function isValidChantSession(data) {
      return data.keys().hasAll(['chantId', 'count', 'timestamp']) &&
             data.chantId is string && data.chantId.size() <= 128 &&
             data.count is number && data.count > 0 &&
             (data.timestamp is timestamp || data.timestamp is number);
    }

    function isValidMeditationSession(data) {
      return data.keys().hasAll(['date', 'durationMin']) &&
             data.date is string &&
             data.durationMin is number;
    }

    // --- Rules ---

    // Configs
    match /configs/calendar {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reflections
    match /reflections/{reflectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Global Chants
    match /chants/{chantId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(chantId) && isValidGlobalChant(incoming());
    }

    // User Chants
    match /users/{userId}/chants/{userChantId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userChantId) && isValidUserChant(incoming(), userId);
      allow update: if isOwner(userId) && isValidUserChant(incoming(), userId);
      allow delete: if isOwner(userId);
    }

    // Chant Sessions
    match /users/{userId}/chant_sessions/{sessionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(sessionId) && isValidChantSession(incoming());
      // Sessions are immutable
      allow update, delete: if false;
    }

    // Meditation Sessions
    match /users/{userId}/meditation_sessions/{sessionId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidId(sessionId) && isValidMeditationSession(incoming());
      allow delete: if false;
    }
  }
}
